// ─── STATS ──────────────────────────────────────────────────────────────────
function stats() {
  var done = trades.filter(function(t) { return t.result; });
  var wins = done.filter(function(t) { return t.result === 'WIN'; });
  var losses = done.filter(function(t) { return t.result === 'LOSS'; });
  var bes = done.filter(function(t) { return t.result === 'BE'; });
  var total = done.length;
  var wr = total ? wins.length / total * 100 : 0;
  var pnls = done.map(function(t) { return parseFloat(t.pnl) || 0; });
  var totalPnl = pnls.reduce(function(a, b) { return a + b; }, 0);
  var winPnls = wins.map(function(t) { return parseFloat(t.pnl) || 0; });
  var lossPnls = losses.map(function(t) { return parseFloat(t.pnl) || 0; });
  var avgWin = wins.length ? winPnls.reduce(function(a,b){return a+b;}, 0) / wins.length : 0;
  var avgLoss = losses.length ? lossPnls.reduce(function(a,b){return a+b;}, 0) / losses.length : 0;
  var best = pnls.length ? Math.max.apply(null, pnls) : 0;
  var worst = pnls.length ? Math.min.apply(null, pnls) : 0;
  var rrs = done.map(function(t) { return parseFloat(t.rr); }).filter(function(v) { return !isNaN(v) && v !== 0; });
  var avgRR = rrs.length ? rrs.reduce(function(a,b){return a+b;}, 0) / rrs.length : 0;
  var planRRs = done.map(function(t) { return parseFloat(t.planRR); }).filter(function(v) { return !isNaN(v) && v > 0; });
  var avgPlanRR = planRRs.length ? planRRs.reduce(function(a,b){return a+b;}, 0) / planRRs.length : 0;
  var totalPips = done.map(function(t) { return parseFloat(t.pips) || 0; }).reduce(function(a,b){return a+b;}, 0);
  var ems = done.map(function(t) { return parseInt(t.emo); }).filter(function(v) { return !isNaN(v); });
  var avgEm = ems.length ? ems.reduce(function(a,b){return a+b;}, 0) / ems.length : 0;
  var pf = (losses.length && Math.abs(avgLoss) > 0) ? Math.abs((avgWin * wins.length) / (avgLoss * losses.length)) : (losses.length === 0 && wins.length > 0 ? 999 : 0);

  // Streak
  var curStr = 0, maxStr = 0, curType = '', strType = '';
  done.forEach(function(t) {
    if (t.result === 'WIN') {
      curType === 'WIN' ? curStr++ : (curStr = 1, curType = 'WIN');
      maxStr = Math.max(maxStr, curStr);
    } else if (t.result === 'LOSS') {
      curType === 'LOSS' ? curStr++ : (curStr = 1, curType = 'LOSS');
    } else { curStr = 0; }
    strType = curType;
  });

  // Max drawdown
  var peak = sett.acct, maxDDval = 0, runEq = sett.acct;
  done.forEach(function(t) {
    runEq += parseFloat(t.pnl) || 0;
    if (runEq > peak) peak = runEq;
    var dd = peak > 0 ? (peak - runEq) / peak * 100 : 0;
    if (dd > maxDDval) maxDDval = dd;
  });

  // Today
  var today = new Date().toISOString().slice(0, 10);
  var todayT = done.filter(function(t) { return t.date === today; });
  var todayPnl = todayT.map(function(t) { return parseFloat(t.pnl) || 0; }).reduce(function(a,b){return a+b;}, 0);

  // Session map
  var sessMap = {};
  done.forEach(function(t) {
    var s = t.sess || 'London';
    if (!sessMap[s]) sessMap[s] = { t: 0, w: 0, l: 0, pnl: 0, pips: 0 };
    sessMap[s].t++;
    if (t.result === 'WIN') sessMap[s].w++;
    else if (t.result === 'LOSS') sessMap[s].l++;
    sessMap[s].pnl += parseFloat(t.pnl) || 0;
    sessMap[s].pips += parseFloat(t.pips) || 0;
  });

  // Monthly
  var monthMap = {};
  done.forEach(function(t) {
    if (!t.date) return;
    var m = new Date(t.date).toLocaleString('default', { month: 'short' });
    if (!monthMap[m]) monthMap[m] = { pnl: 0, t: 0, w: 0 };
    monthMap[m].pnl += parseFloat(t.pnl) || 0;
    monthMap[m].t++;
    if (t.result === 'WIN') monthMap[m].w++;
  });

  // Setup map
  var setupMap = {};
  done.forEach(function(t) {
    if (!t.setup) return;
    if (!setupMap[t.setup]) setupMap[t.setup] = { t: 0, w: 0, pnl: 0 };
    setupMap[t.setup].t++;
    if (t.result === 'WIN') setupMap[t.setup].w++;
    setupMap[t.setup].pnl += parseFloat(t.pnl) || 0;
  });

  // Emotion map
  var emoMap = {};
  done.forEach(function(t) {
    var e = parseInt(t.emo) || 5;
    if (!emoMap[e]) emoMap[e] = { t: 0, w: 0 };
    emoMap[e].t++;
    if (t.result === 'WIN') emoMap[e].w++;
  });

  // Day map
  var dayMap = {};
  done.forEach(function(t) {
    if (!t.date) return;
    dayMap[t.date] = (dayMap[t.date] || 0) + (parseFloat(t.pnl) || 0);
  });
  var dayVals = Object.values(dayMap);
  var bestDay = dayVals.length ? Math.max.apply(null, dayVals) : 0;
  var worstDay = dayVals.length ? Math.min.apply(null, dayVals) : 0;

  // Equity
  var equity = [sett.acct];
  done.forEach(function(t) { equity.push(equity[equity.length - 1] + (parseFloat(t.pnl) || 0)); });
  var curEq = equity[equity.length - 1] || sett.acct;

  return {
    done: done, wins: wins, losses: losses, bes: bes, total: total, wr: wr,
    pnls: pnls, totalPnl: totalPnl, avgWin: avgWin, avgLoss: avgLoss,
    best: best, worst: worst, avgRR: avgRR, avgPlanRR: avgPlanRR,
    totalPips: totalPips, avgEm: avgEm, pf: pf,
    curStr: curStr, maxStr: maxStr, strType: strType,
    maxDD: maxDDval, todayT: todayT, todayPnl: todayPnl,
    sessMap: sessMap, monthMap: monthMap, setupMap: setupMap,
    emoMap: emoMap, dayMap: dayMap, bestDay: bestDay, worstDay: worstDay,
    equity: equity, curEq: curEq
  };
}

