function findWeaks(s) {
  var w = [];
  if (s.total < 5) return w;
  var hiEmLoss = s.done.filter(function(t) { return parseInt(t.emo) >= 8 && t.result === 'LOSS'; });
  if (hiEmLoss.length >= 2) w.push({ ic: '😤', tx: 'Lost ' + hiEmLoss.length + ' trades with emotion ≥8. Stop trading when overconfident.' });
  Object.keys(s.sessMap).forEach(function(sess) {
    var d = s.sessMap[sess];
    if (d.t >= 3 && d.w / d.t < 0.4) w.push({ ic: '📍', tx: sess + ' session: only ' + Math.round(d.w / d.t * 100) + '% WR. Reduce size or avoid entirely.' });
  });
  ['BUY', 'SELL'].forEach(function(dir) {
    var dt = s.done.filter(function(t) { return t.direction === dir; });
    var dl = dt.filter(function(t) { return t.result === 'LOSS'; });
    if (dt.length >= 3 && dl.length / dt.length > 0.6) w.push({ ic: dir === 'BUY' ? '⬆️' : '⬇️', tx: dir + ' trades losing ' + Math.round(dl.length / dt.length * 100) + '% of the time. Check your bias.' });
  });
  if (s.avgRR < 1.5 && s.total >= 5) w.push({ ic: '✂️', tx: 'Avg R:R ' + s.avgRR.toFixed(2) + '. Cutting winners too early. Target 2.0+' });
  var noR = s.done.filter(function(t) { return !t.reason; }).length;
  if (noR > 0) w.push({ ic: '📝', tx: noR + ' trades with no entry reason. Bad habits hide in blank fields.' });
  if (s.maxDD > sett.maxDD * 2) w.push({ ic: '📉', tx: 'Max drawdown ' + s.maxDD.toFixed(1) + '% is dangerous. Cut risk per trade.' });
  return w;
}

function findInsights(s) {
  var ins = [];
  if (s.total < 5) return ins;
  var sessKeys = Object.keys(s.sessMap);
  if (sessKeys.length > 0) {
    var best = sessKeys.slice().sort(function(a, b) { return (s.sessMap[b].w / s.sessMap[b].t) - (s.sessMap[a].w / s.sessMap[a].t); })[0];
    ins.push({ ic: '🌍', tx: 'Best session: ' + best + ' with ' + Math.round(s.sessMap[best].w / s.sessMap[best].t * 100) + '% WR. Trade more here.' });
  }
  var suKeys = Object.keys(s.setupMap);
  if (suKeys.length > 0) {
    var bestSu = suKeys.slice().sort(function(a, b) { return (s.setupMap[b].w / s.setupMap[b].t) - (s.setupMap[a].w / s.setupMap[a].t); })[0];
    if (s.setupMap[bestSu].t >= 2) ins.push({ ic: '🎯', tx: 'Best setup: ' + bestSu + ' with ' + Math.round(s.setupMap[bestSu].w / s.setupMap[bestSu].t * 100) + '% WR. Focus on this.' });
  }
  var goodEm = s.done.filter(function(t) { return parseInt(t.emo) >= 4 && parseInt(t.emo) <= 7; });
  var goodWR = goodEm.length ? goodEm.filter(function(t) { return t.result === 'WIN'; }).length / goodEm.length * 100 : 0;
  if (goodWR > s.wr + 5) ins.push({ ic: '🧠', tx: goodWR.toFixed(0) + '% WR when emotion 4–7 vs ' + s.wr.toFixed(0) + '% overall. Emotion control works.' });
  return ins;
}

