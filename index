   ['Monthly Goal ($)', 'monthGoal', 10], ['Challenge Target %', 'chalTarget', 0.1]].map(function(r) {
    return '<div class="fg"><label class="lb">' + r[0] + '</label><input type="number" step="' + r[2] + '" id="si-' + r[1] + '" value="' + sett[r[1]] + '"></div>';
  }).join('') + '</div>' +
  '<div class="sr-row"><span class="sr-lbl">FTMO / Challenge Mode</span><div class="tog' + (sett.chalMode ? ' on' : '') + '" id="chal-tog" onclick="togChal()"></div></div>' +
  '<div class="mbr"><button class="bc" onclick="closeSett()">CANCEL</button><button class="bs" onclick="saveSett()">SAVE</button></div>' +
  '<div style="margin-top:13px;padding-top:13px;border-top:1px solid #ffffff08"><div style="font-size:8px;color:var(--sb);margin-bottom:8px;letter-spacing:2px">DATA</div>' +
  '<div style="display:flex;gap:8px"><button class="bgh" onclick="expCSV()">📤 CSV</button><button class="bd" onclick="clearAll()" style="font-size:10px">🗑️ CLEAR ALL</button></div></div>';
  document.getElementById('ov-sett').style.display = 'flex';
}
function closeSett() { document.getElementById('ov-sett').style.display = 'none'; }
function togChal() {
  sett.chalMode = !sett.chalMode;
  var el = document.getElementById('chal-tog');
  if (el) el.className = 'tog' + (sett.chalMode ? ' on' : '');
}
function saveSett() {
  ['acct','risk','maxDD','maxWDD','twrTarget','trrTarget','monthGoal','chalTarget'].forEach(function(k) {
    var el = document.getElementById('si-' + k);
    if (el) { var v = parseFloat(el.value); if (!isNaN(v)) sett[k] = v; }
  });
  saveS();
  closeSett();
  render();
}
function clearAll() {
  if (confirm('Delete ALL trades and journals? Cannot be undone.')) {
    trades = []; journals = []; saveT(); saveJ(); closeSett(); render();
  }
}

// ─── EXPORT CSV ─────────────────────────────────────────────────────────────
function expCSV() {
  if (!trades.length) { alert('No trades to export.'); return; }
  var headers = 'Date,Session,Direction,Entry,SL,TP,Lots,Exit,Result,PnL,Pips,Risk,RR,PlanRR,Emotion,Setup,TF,Stars,Reason,Notes';
  var rows = trades.map(function(t) {
    return [t.date,t.sess,t.direction,t.entry,t.sl,t.tp,t.lots,t.exit,t.result,t.pnl,t.pips,t.risk,t.rr,t.planRR,t.emo,t.setup,t.tf,t.stars,'"'+(t.reason||'').replace(/"/g,'""')+'"','"'+(t.notes||'').replace(/"/g,'""')+'"'].join(',');
  });
  var csv = headers + '\n' + rows.join('\n');
  var a = document.createElement('a');
  a.href = 'data:text/csv;charset=utf-8,' + encodeURIComponent(csv);
  a.download = 'XAU_Trades_' + new Date().toISOString().slice(0,10) + '.csv';
  a.click();
}

// ─── FORM ────────────────────────────────────────────────────────────────────
function openAdd() {
  editId = null;
  document.getElementById('add-title').textContent = '➕ Log Trade';
  document.getElementById('fd').value = new Date().toISOString().slice(0,10);
  document.getElementById('fss').value = 'London';
  document.getElementById('fb2').value = 'Bullish';
  document.getElementById('fdi').value = 'BUY';
  styleDir(document.getElementById('fdi'));
  ['fen','fsl','ftp','flt','fex','fre','fno'].forEach(function(id) { var el = document.getElementById(id); if (el) el.value = ''; });
  var rs = document.getElementById('frs'); if (rs) rs.value = '';
  var st = document.getElementById('fst'); if (st) st.value = '';
  var tf = document.getElementById('ftf'); if (tf) tf.value = '';
  buildEMG('emg', '5', function(v) { selEmo = v; });
  buildStars(3);
  var cp = document.getElementById('cprev'); if (cp) cp.style.display = 'none';
  document.getElementById('ov-add').style.display = 'flex';
}
function closeAdd() { document.getElementById('ov-add').style.display = 'none'; }

function editT(id) {
  var t = trades.find(function(x) { return x.id == id; });
  if (!t) return;
  editId = id;
  document.getElementById('add-title').textContent = '✏️ Edit Trade';
  var set2 = function(id2, val) { var el = document.getElementById(id2); if (el) el.value = val || ''; };
  set2('fd', t.date); set2('fss', t.sess || 'London'); set2('fb2', t.bias || 'Bullish');
  set2('fdi', t.direction || 'BUY'); styleDir(document.getElementById('fdi'));
  set2('fen', t.entry); set2('fsl', t.sl); set2('ftp', t.tp); set2('flt', t.lots);
  set2('fex', t.exit); set2('frs', t.result || ''); set2('fst', t.setup || ''); set2('ftf', t.tf || '');
  set2('fre', t.reason); set2('fno', t.notes);
  buildEMG('emg', t.emo || '5', function(v) { selEmo = v; });
  selEmo = t.emo || '5';
  buildStars(parseInt(t.stars) || 3);
  autoCalc();
  document.getElementById('ov-add').style.display = 'flex';
}

function styleDir(sel) { if (!sel) return; sel.style.color = sel.value === 'BUY' ? '#00C896' : '#FF4757'; sel.style.fontWeight = '700'; }

function buildEMG(gid, sel, callback) {
  var g = document.getElementById(gid);
  if (!g) return;
  g.innerHTML = '';
  for (var n = 1; n <= 10; n++) {
    (function(num) {
      var b = document.createElement('button');
      b.type = 'button'; b.textContent = num; b.className = 'emb';
      var active = String(num) === String(sel);
      if (active) { b.style.borderColor = '#C9A84C'; b.style.background = '#C9A84C'; b.style.color = '#000'; }
      b.onclick = function() { callback(String(num)); buildEMG(gid, num, callback); };
      g.appendChild(b);
    })(n);
  }
  var w = document.getElementById('em-w');
  if (w && gid === 'emg') w.style.display = parseInt(sel) >= 8 ? 'block' : 'none';
}

function buildStars(sel) {
  selStar = sel;
  var g = document.getElementById('stg');
  if (!g) return;
  g.innerHTML = '';
  for (var n = 1; n <= 5; n++) {
    (function(num) {
      var b = document.createElement('button');
      b.type = 'button'; b.className = 'stb';
      b.textContent = '★'; b.style.color = num <= sel ? '#FFD700' : '#2a2a2a';
      b.onclick = function() { buildStars(num); };
      g.appendChild(b);
    })(n);
  }
}

function autoCalc() {
  var dir = document.getElementById('fdi') ? document.getElementById('fdi').value : 'BUY';
  var entry = parseFloat(document.getElementById('fen') ? document.getElementById('fen').value : '');
  var sl = parseFloat(document.getElementById('fsl') ? document.getElementById('fsl').value : '');
  var tp = parseFloat(document.getElementById('ftp') ? document.getElementById('ftp').value : '');
  var lots = parseFloat(document.getElementById('flt') ? document.getElementById('flt').value : '');
  var exit2 = parseFloat(document.getElementById('fex') ? document.getElementById('fex').value : '');
  var m = dir === 'BUY' ? 1 : -1;
  var risk = ''; var pnl = ''; var pips = ''; var rr = ''; var planRR = '';
  if (entry && sl && lots) risk = (Math.abs(entry - sl) * lots * 100).toFixed(2);
  if (entry && sl && tp) {
    var slP = Math.abs(entry - sl) * 100;
    var tpP = Math.abs(tp - entry) * 100;
    if (slP > 0) planRR = (tpP / slP).toFixed(2);
  }
  if (entry && lots && exit2) {
    pnl = (m * (exit2 - entry) * lots * 100).toFixed(2);
    pips = (m * (exit2 - entry) * 100).toFixed(1);
  }
  if (pnl && risk && parseFloat(risk) !== 0) rr = (parseFloat(pnl) / parseFloat(risk)).toFixed(2);
  var cp = document.getElementById('cprev');
  if (!cp) return;
  var parts = [];
  if (risk) parts.push('⚠️ Risk: <b style="color:#FF4757">$' + risk + '</b>');
  if (planRR) parts.push('🎯 Plan: <b style="color:#C9A84C">' + planRR + 'R</b>');
  if (pnl) parts.push('💰 P&L: <b style="color:' + (parseFloat(pnl) >= 0 ? '#00C896' : '#FF4757') + '">$' + parseFloat(pnl).toFixed(2) + '</b>');
  if (rr) parts.push('📏 R:R: <b style="color:' + (parseFloat(rr) >= 2 ? '#00C896' : parseFloat(rr) >= 1 ? '#FFD700' : '#FF4757') + '">' + rr + 'R</b>');
  if (pips) parts.push('📈 Pips: <b style="color:#888">' + pips + '</b>');
  if (parts.length > 0) { cp.style.display = 'flex'; cp.innerHTML = parts.join(''); }
  else cp.style.display = 'none';
}

function saveTrade() {
  var entry = document.getElementById('fen') ? document.getElementById('fen').value : '';
  if (!entry) { alert('Entry price required.'); return; }
  var dir = document.getElementById('fdi') ? document.getElementById('fdi').value : 'BUY';
  var sl = parseFloat(document.getElementById('fsl') ? document.getElementById('fsl').value : '');
  var tp = parseFloat(document.getElementById('ftp') ? document.getElementById('ftp').value : '');
  var lots = parseFloat(document.getElementById('flt') ? document.getElementById('flt').value : '');
  var exit2 = parseFloat(document.getElementById('fex') ? document.getElementById('fex').value : '');
  var entryNum = parseFloat(entry);
  var m = dir === 'BUY' ? 1 : -1;
  var risk = ''; var pnl = ''; var pips = ''; var rr = ''; var planRR = ''; var result = document.getElementById('frs') ? document.getElementById('frs').value : '';
  if (entryNum && sl && lots) risk = (Math.abs(entryNum - sl) * lots * 100).toFixed(2);
  if (entryNum && sl && tp) {
    var slP2 = Math.abs(entryNum - sl) * 100;
    var tpP2 = Math.abs(tp - entryNum) * 100;
    if (slP2 > 0) planRR = (tpP2 / slP2).toFixed(2);
  }
  if (entryNum && lots && exit2) {
    pnl = (m * (exit2 - entryNum) * lots * 100).toFixed(2);
    pips = (m * (exit2 - entryNum) * 100).toFixed(1);
    if (!result) result = parseFloat(pnl) > 0 ? 'WIN' : parseFloat(pnl) < 0 ? 'LOSS' : 'BE';
  }
  if (pnl && risk && parseFloat(risk) !== 0) rr = (parseFloat(pnl) / parseFloat(risk)).toFixed(2);
  var t = {
    id: editId || Date.now(),
    date: document.getElementById('fd') ? document.getElementById('fd').value : '',
    sess: document.getElementById('fss') ? document.getElementById('fss').value : '',
    bias: document.getElementById('fb2') ? document.getElementById('fb2').value : '',
    direction: dir, entry: entry,
    sl: document.getElementById('fsl') ? document.getElementById('fsl').value : '',
    tp: document.getElementById('ftp') ? document.getElementById('ftp').value : '',
    lots: document.getElementById('flt') ? document.getElementById('flt').value : '',
    exit: document.getElementById('fex') ? document.getElementById('fex').value : '',
    result: result, risk: risk, pnl: pnl, pips: pips, rr: rr, planRR: planRR,
    setup: document.getElementById('fst') ? document.getElementById('fst').value : '',
    tf: document.getElementById('ftf') ? document.getElementById('ftf').value : '',
    reason: document.getElementById('fre') ? document.getElementById('fre').value : '',
    notes: document.getElementById('fno') ? document.getElementById('fno').value : '',
    emo: selEmo, stars: selStar
  };
  if (editId) { trades = trades.map(function(x) { return x.id == editId ? t : x; }); }
  else { trades.push(t); }
  saveT(); closeAdd(); render();
}

// ─── DELETE ──────────────────────────────────────────────────────────────────
function openDel(id) { delId = id; document.getElementById('ov-del').style.display = 'flex'; }
function closeDel() { delId = null; document.getElementById('ov-del').style.display = 'none'; }
function confirmDel() {
  if (delId) {
    trades = trades.filter(function(t) { return t.id != delId; });
    saveT(); closeDel(); render();
  }
}

// ─── CHECKLIST ───────────────────────────────────────────────────────────────
function openCL() { renderCL(); document.getElementById('ov-cl').style.display = 'flex'; }
function closeCL() { document.getElementById('ov-cl').style.display = 'none'; }
function renderCL() {
  var done = cl.filter(function(v) { return v === 'YES'; }).length;
  var fail = cl.filter(function(v) { return v === 'NO'; }).length;
  var cleared = done === 12 && fail === 0;
  var sc = cleared ? '#00C896' : fail ? '#FF4757' : '#FFD700';
  var st = cleared ? '✅ CLEARED' : fail ? '🚫 NOT READY' : '⏳ FILL ALL';
  var html = '<div class="mh"><span class="mt">✅ Pre-Trade Checklist</span><button class="mx" onclick="closeCL()">✕</button></div>';
  html += '<div class="clst"><span style="color:var(--sb)">' + done + '/12 YES</span><span style="font-weight:700;color:' + sc + '">' + st + '</span></div>';
  CL_Q.forEach(function(q, i) {
    var v = cl[i] || '';
    var bc = v === 'YES' ? '#00C89622' : v === 'NO' ? '#FF475722' : '#ffffff0A';
    var bbc = v === 'YES' ? '#00C89633' : v === 'NO' ? '#FF475533' : '#ffffff0F';
    html += '<div class="cli" style="border:1px solid ' + bbc + '"><div class="clq">' + (i+1) + '. ' + q + '</div><div class="clb">';
    ['YES','NO','N/A'].forEach(function(opt) {
      var ac = v === opt;
      var c = opt === 'YES' ? '#00C896' : opt === 'NO' ? '#FF4757' : '#FFD700';
      html += '<button class="clbt" style="' + (ac ? 'border-color:' + c + ';background:' + c + '22;color:' + c : '') + '" onclick="setCL(' + i + ',\'' + opt + '\')">' + (opt === 'YES' ? '✅' : opt === 'NO' ? '❌' : '⚠️') + ' ' + opt + '</button>';
    });
    html += '</div></div>';
  });
  html += '<div class="mbr"><button class="bc" onclick="cl=Array(12).fill(\'\');renderCL()">RESET</button>';
  if (cleared) html += '<button class="bs" onclick="closeCL();openAdd()">CLEARED — LOG TRADE</button>';
  else html += '<button class="bgh" style="flex:2" onclick="closeCL()">CLOSE</button>';
  html += '</div>';
  document.getElementById('cl-body').innerHTML = html;
}
function setCL(i, v) { cl[i] = cl[i] === v ? '' : v; renderCL(); }

// ─── TAB ROUTING ─────────────────────────────────────────────────────────────
var tabMap = { ov: 'pov', ch: 'pch', tr: 'ptr', an: 'pan', rc: 'prc', gl: 'pgl', jn: 'pjn' };
function goTab(name, btn) {
  document.querySelectorAll('.tab').forEach(function(t) { t.className = 'tab'; });
  btn.className = 'tab on';
  Object.keys(tabMap).forEach(function(k) { document.getElementById(tabMap[k]).style.display = 'none'; });
  document.getElementById(tabMap[name]).style.display = 'block';
  destroyCharts();
  if (name === 'ov') renderOV();
  else if (name === 'ch') renderCH();
  else if (name === 'tr') renderTR();
  else if (name === 'an') renderAN();
  else if (name === 'rc') renderRC();
  else if (name === 'gl') renderGL();
  else if (name === 'jn') renderJN();
}

// ─── MAIN RENDER ─────────────────────────────────────────────────────────────
function render() {
  renderAB();
  var onTab = document.querySelector('.tab.on');
  var name = onTab ? onTab.getAttribute('onclick').match(/'(\w+)'/)[1] : 'ov';
  if (name === 'ov') renderOV();
  else if (name === 'ch') renderCH();
  else if (name === 'tr') renderTR();
  else if (name === 'an') renderAN();
  else if (name === 'rc') renderRC();
  else if (name === 'gl') renderGL();
  else if (name === 'jn') renderJN();
}

// ─── INIT ────────────────────────────────────────────────────────────────────
cl = Array(12).fill('');
render();
</script>
