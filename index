<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#080c12">
<title>⚡ XAU Tracker Pro</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
:root{--g:#C9A84C;--g2:#FFD700;--dk:#080c12;--cd:#0d1117;--md:#16213E;--gr:#00C896;--rd:#FF4757;--yw:#FFD700;--pu:#6C63FF;--tx:#aaa;--sb:#555;--br:#C9A84C1A}
html,body{height:100%;background:var(--dk);color:#fff;font-family:'DM Mono',monospace;overflow-x:hidden}
canvas.grain{position:fixed;inset:0;width:100%;height:100%;pointer-events:none;z-index:1}
#app{position:relative;z-index:2;min-height:100vh;max-width:540px;margin:0 auto}
.hdr{background:linear-gradient(180deg,#0d1117,#080c12);border-bottom:1px solid var(--br);padding:14px 14px 10px;position:sticky;top:0;z-index:10}
.hdr-r1{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:9px}
.lg-s{font-size:9px;color:var(--g);letter-spacing:3px;text-transform:uppercase}
.lg-m{font-family:'Playfair Display',serif;font-size:20px;background:linear-gradient(135deg,#C9A84C,#FFD700,#8B6914);-webkit-background-clip:text;-webkit-text-fill-color:transparent;line-height:1.1}
.lg-m2{font-family:'Playfair Display',serif;font-size:20px;color:#fff;line-height:1.1}
.hdr-a{display:flex;flex-direction:column;gap:5px;align-items:flex-end}
.bg{background:linear-gradient(135deg,#C9A84C,#8B6914);border:none;border-radius:9px;color:#000;font-weight:800;font-size:11px;padding:9px 13px;cursor:pointer;letter-spacing:1px;text-transform:uppercase;font-family:inherit}
.gg{background:transparent;border:1px solid #C9A84C33;border-radius:7px;color:var(--g);font-size:9px;font-weight:700;padding:5px 10px;cursor:pointer;font-family:inherit}
.hdr-a2{display:flex;gap:5px;margin-top:2px}
.ab{background:var(--cd);border:1px solid var(--br);border-radius:10px;padding:8px 10px;display:grid;grid-template-columns:repeat(4,1fr);gap:2px}
.ai{text-align:center}.al{font-size:7px;color:var(--sb);letter-spacing:1px;text-transform:uppercase;margin-bottom:2px}.av{font-size:11px;font-weight:700}
.tabs{display:flex;padding:7px 10px 0;gap:3px;border-bottom:1px solid var(--br);background:var(--dk);position:sticky;top:128px;z-index:9;overflow-x:auto}
.tabs::-webkit-scrollbar{display:none}
.tab{padding:6px 10px;border-radius:6px 6px 0 0;font-size:9px;font-weight:700;letter-spacing:1px;text-transform:uppercase;border:none;cursor:pointer;background:transparent;color:var(--sb);font-family:inherit;white-space:nowrap;flex-shrink:0;transition:all .2s}
.tab.on{background:var(--g);color:#000}
.pane{padding-bottom:40px;animation:fu .3s ease}
@keyframes fu{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
.sec{color:var(--g);font-size:9px;font-weight:700;letter-spacing:3px;text-transform:uppercase;padding:14px 13px 6px;display:flex;justify-content:space-between;align-items:center}
.card{background:var(--cd);border:1px solid var(--br);border-radius:12px;margin:0 11px 8px;padding:13px;overflow:hidden}
.kg{display:grid;grid-template-columns:1fr 1fr;gap:8px;padding:10px 11px 0}
.kc{background:var(--cd);border-radius:11px;padding:12px 11px;position:relative;overflow:hidden;border:1px solid transparent}
.ki{position:absolute;top:-10px;right:-6px;font-size:38px;opacity:.06}
.kl{font-size:8px;color:var(--sb);letter-spacing:2px;text-transform:uppercase;margin-bottom:5px}
.kv{font-family:'Playfair Display',serif;font-size:18px;line-height:1;font-weight:700}
.ks{font-size:8px;color:var(--sb);margin-top:3px}
.kb{height:2px;background:#ffffff0E;border-radius:1px;margin-top:7px}
.kf{height:100%;border-radius:1px;transition:width 1.2s ease}
.str{background:linear-gradient(135deg,#C9A84C18,#C9A84C06);border:1px solid #C9A84C28;border-radius:11px;margin:8px 11px 0;padding:11px 13px;display:flex;justify-content:space-between;align-items:center}
.sn{font-family:'Playfair Display',serif;font-size:26px;line-height:1}
.sl{font-size:8px;color:var(--sb);letter-spacing:2px;text-transform:uppercase;margin-top:2px}
.sr{text-align:right;font-size:9px}
.ddb{background:#FF475710;border:1px solid #FF475720;border-radius:9px;overflow:hidden;position:relative;height:24px;margin:0 11px 6px}
.ddf{height:100%;border-radius:8px;display:flex;align-items:center;padding-left:8px;transition:width 1s ease}
.ddl{font-size:8px;font-weight:700;color:#fff}
.ddlim{position:absolute;right:8px;top:50%;transform:translateY(-50%);font-size:8px;color:#FF4757}
.ch{background:linear-gradient(135deg,#0d1117,#16213E);border:1px solid #C9A84C28;border-radius:12px;margin:0 11px 8px;padding:13px}
.chg{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-bottom:9px}
.chi{text-align:center}.chl{font-size:7px;color:var(--sb);margin-bottom:2px}.chv{font-size:13px;font-weight:700}
.chb{height:5px;background:#ffffff0A;border-radius:3px;overflow:hidden;margin-top:8px}
.chf{height:100%;border-radius:3px;transition:width 1s ease}
.tr{background:var(--cd);border:1px solid var(--br);border-radius:11px;margin:0 11px 7px;padding:11px 13px;cursor:pointer;transition:transform .15s;border-left-width:3px}
.tr:active{transform:scale(.98)}
.tt{display:flex;justify-content:space-between;margin-bottom:4px;align-items:flex-start}
.ttg{display:flex;gap:6px;align-items:center;flex-wrap:wrap;flex:1}
.td{font-size:10px;font-weight:700}
.tm{font-size:9px;color:#3a3a3a}
.tp{font-size:12px;font-weight:700;font-family:'Playfair Display',serif;flex-shrink:0}
.tb{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:3px}
.tdt{display:flex;gap:8px;font-size:9px;color:var(--sb)}
.rb{font-size:9px;font-weight:700;padding:2px 7px;border-radius:4px}
.trs{font-size:8px;color:#333;margin-top:4px;font-style:italic;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}
.ov{position:fixed;inset:0;background:#000000e0;z-index:50;display:flex;align-items:flex-end;justify-content:center}
.ovc{align-items:center}
.mo{background:#0d1117;border:1px solid #C9A84C22;border-radius:18px 18px 0 0;padding:20px 14px 34px;width:100%;max-width:540px;max-height:92vh;overflow-y:auto}
.moc{border-radius:15px;max-width:330px;padding:24px 18px;text-align:center}
.mh{display:flex;justify-content:space-between;align-items:center;margin-bottom:15px}
.mt{color:var(--g);font-size:14px;font-family:'Playfair Display',serif;font-weight:700}
.mx{background:none;border:none;color:#555;font-size:20px;cursor:pointer}
.fg{display:flex;flex-direction:column;margin-bottom:9px}
.fg2{display:grid;grid-template-columns:1fr 1fr;gap:9px}
label.lb{color:var(--g);font-size:9px;font-weight:700;letter-spacing:2px;text-transform:uppercase;margin-bottom:4px}
input,select,textarea{background:#080c12;border:1px solid #C9A84C28;border-radius:7px;color:#fff;padding:9px 10px;font-size:12px;font-family:inherit;outline:none;width:100%}
input:focus,select:focus{border-color:#C9A84C66}
select option{background:#0d1117}
input[type=number]::-webkit-inner-spin-button{opacity:.3}
.emg{display:flex;gap:4px;flex-wrap:wrap}
.emb{flex:1 0 auto;min-width:25px;padding:6px 0;border-radius:6px;border:1px solid #2a2a2a;background:transparent;color:#555;font-weight:700;font-size:11px;cursor:pointer;font-family:inherit;transition:all .1s}
.stg{display:flex;gap:7px}
.stb{font-size:19px;background:none;border:none;cursor:pointer;padding:2px;transition:transform .1s}
.stb:active{transform:scale(1.3)}
.cp{margin-top:9px;padding:9px 11px;background:#C9A84C08;border:1px solid #C9A84C18;border-radius:8px;display:flex;gap:11px;flex-wrap:wrap;font-size:10px}
.wn{color:#FF4757;font-size:9px;font-weight:700;margin-top:4px}
.mbr{display:flex;gap:8px;margin-top:13px}
.bc{flex:1;background:#ffffff08;border:1px solid #2a2a2a;border-radius:8px;color:#666;font-weight:700;font-size:11px;padding:11px 0;cursor:pointer;font-family:inherit}
.bs{flex:2;background:linear-gradient(135deg,#C9A84C,#8B6914);border:none;border-radius:8px;color:#000;font-weight:800;font-size:11px;padding:11px 0;cursor:pointer;font-family:inherit}
.bd{flex:1;background:#FF475718;border:1px solid #FF475740;border-radius:8px;color:#FF4757;font-weight:800;font-size:11px;padding:11px 0;cursor:pointer;font-family:inherit}
.bgh{flex:1;background:transparent;border:1px solid #C9A84C33;border-radius:8px;color:var(--g);font-weight:700;font-size:11px;padding:11px 0;cursor:pointer;font-family:inherit}
.sr-row{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid #ffffff06}
.sr-lbl{font-size:11px;color:#aaa}
.sr-v{font-size:11px;font-weight:700;color:var(--g)}
.tog{width:38px;height:20px;background:#333;border-radius:10px;position:relative;cursor:pointer;transition:background .2s;flex-shrink:0}
.tog.on{background:var(--gr)}
.tog::after{content:'';position:absolute;width:14px;height:14px;background:#fff;border-radius:50%;top:3px;left:3px;transition:left .2s}
.tog.on::after{left:21px}
.cli{margin-bottom:6px;padding:9px 11px;border-radius:9px;background:#0d1117}
.clq{font-size:10px;color:#aaa;margin-bottom:7px;line-height:1.4}
.clb{display:flex;gap:5px}
.clbt{flex:1;padding:6px 0;border-radius:6px;border:1px solid #222;background:transparent;color:#555;font-weight:700;font-size:10px;cursor:pointer;font-family:inherit;transition:all .1s}
.clst{margin-bottom:9px;padding:8px 11px;background:#C9A84C0C;border:1px solid #C9A84C18;border-radius:9px;display:flex;justify-content:space-between;font-size:9px}
.gc{background:var(--cd);border:1px solid var(--br);border-radius:11px;margin:0 11px 8px;padding:12px}
.gt{display:flex;justify-content:space-between;margin-bottom:7px}
.gb{height:9px;background:#ffffff0A;border-radius:5px;overflow:hidden;margin-bottom:4px}
.gf{height:100%;border-radius:5px;transition:width 1s ease}
.gm{display:flex;justify-content:space-between;font-size:8px;color:var(--sb)}
.fb{display:flex;gap:5px;padding:8px 11px 6px;overflow-x:auto}
.fb::-webkit-scrollbar{display:none}
.fbt{padding:4px 10px;border-radius:14px;font-size:8px;font-weight:700;letter-spacing:1px;border:1px solid #2a2a2a;background:transparent;color:#555;cursor:pointer;font-family:inherit;white-space:nowrap;flex-shrink:0;transition:all .2s}
.fbt.on{background:var(--g);color:#000;border-color:var(--g)}
.cw{position:relative;height:148px}
.ep{margin-top:9px;padding:6px 11px;background:#C9A84C08;border:1px solid #C9A84C1A;border-radius:7px;font-size:9px;color:var(--g);cursor:pointer;display:inline-block}
.grd{background:var(--cd);border:1px solid var(--br);border-radius:11px;margin:0 11px 8px;padding:12px}
.gt2{display:flex;justify-content:space-between;margin-bottom:6px}
.gb2{background:#ffffff0A;border-radius:4px;height:6px;overflow:hidden}
.gf2{height:100%;border-radius:4px;transition:width 1.5s ease}
.gt3{display:flex;justify-content:space-between;margin-top:4px}
.em-row{display:flex;align-items:center;gap:8px;padding:5px 0;border-bottom:1px solid #ffffff05}
.empty{text-align:center;padding:38px 14px}
.empty-ic{font-size:34px;margin-bottom:9px}
.empty-t{color:var(--g);font-size:12px;font-weight:700;margin-bottom:5px}
.empty-s{color:var(--sb);font-size:10px}
::-webkit-scrollbar{width:2px}
::-webkit-scrollbar-thumb{background:#C9A84C33;border-radius:1px}
</style>
</head>
<body>
<canvas class="grain" id="grain"></canvas>
<div id="app">
  <div class="hdr">
    <div class="hdr-r1">
      <div><div class="lg-s">XAU/USD · GOLD</div><div class="lg-m">PERFORMANCE</div><div class="lg-m2">TRACKER PRO</div></div>
      <div class="hdr-a">
        <button class="bg" onclick="openAdd()">+ LOG TRADE</button>
        <div class="hdr-a2">
          <button class="gg" onclick="openCL()">✅ CHECK</button>
          <button class="gg" onclick="openSett()">⚙️ SETT</button>
          <button class="gg" onclick="expCSV()">📤 CSV</button>
        </div>
      </div>
    </div>
    <div class="ab" id="acct-bar"></div>
  </div>
  <div class="tabs" id="tabs">
    <button class="tab on" onclick="goTab('ov',this)">OVERVIEW</button>
    <button class="tab" onclick="goTab('ch',this)">CHARTS</button>
    <button class="tab" onclick="goTab('tr',this)">TRADES</button>
    <button class="tab" onclick="goTab('an',this)">ANALYSIS</button>
    <button class="tab" onclick="goTab('rc',this)">RISK CALC</button>
    <button class="tab" onclick="goTab('gl',this)">GOALS</button>
    <button class="tab" onclick="goTab('jn',this)">JOURNAL</button>
  </div>
  <div id="pov" class="pane"></div>
  <div id="pch" class="pane" style="display:none"></div>
  <div id="ptr" class="pane" style="display:none"></div>
  <div id="pan" class="pane" style="display:none"></div>
  <div id="prc" class="pane" style="display:none"></div>
  <div id="pgl" class="pane" style="display:none"></div>
  <div id="pjn" class="pane" style="display:none"></div>
</div>

<!-- ADD TRADE -->
<div class="ov" id="ov-add" style="display:none" onclick="if(event.target===this)closeAdd()">
  <div class="mo">
    <div class="mh"><span class="mt" id="add-title">➕ Log Trade</span><button class="mx" onclick="closeAdd()">✕</button></div>
    <div class="fg2">
      <div class="fg"><label class="lb">Date</label><input type="date" id="fd"></div>
      <div class="fg"><label class="lb">Session</label>
        <select id="fss"><option>London</option><option>New York</option><option>Asia</option><option>Sydney</option></select></div>
      <div class="fg"><label class="lb">Bias</label>
        <select id="fb2"><option>Bullish</option><option>Bearish</option><option>Neutral</option></select></div>
      <div class="fg"><label class="lb">Direction</label>
        <select id="fdi" onchange="styleDir(this)"><option value="BUY">BUY ▲</option><option value="SELL">SELL ▼</option></select></div>
      <div class="fg"><label class="lb">Entry</label><input type="number" step="0.01" id="fen" placeholder="2340.50" oninput="autoCalc()"></div>
      <div class="fg"><label class="lb">Stop Loss</label><input type="number" step="0.01" id="fsl" placeholder="2330.00" oninput="autoCalc()"></div>
      <div class="fg"><label class="lb">Take Profit</label><input type="number" step="0.01" id="ftp" placeholder="2360.00" oninput="autoCalc()"></div>
      <div class="fg"><label class="lb">Lot Size</label><input type="number" step="0.01" id="flt" placeholder="0.10" oninput="autoCalc()"></div>
      <div class="fg"><label class="lb">Exit Price</label><input type="number" step="0.01" id="fex" placeholder="After close" oninput="autoCalc()"></div>
      <div class="fg"><label class="lb">Result</label>
        <select id="frs"><option value="">Auto</option><option value="WIN">WIN ✅</option><option value="LOSS">LOSS ❌</option><option value="BE">BE ➖</option></select></div>
      <div class="fg"><label class="lb">Setup Type</label>
        <select id="fst"><option value="">Select</option><option>OB Retest</option><option>FVG Fill</option><option>BOS Entry</option><option>CHoCH Entry</option><option>Supply/Demand</option><option>Liquidity Grab</option><option>Trend Follow</option><option>Reversal</option></select></div>
      <div class="fg"><label class="lb">Timeframe</label>
        <select id="ftf"><option value="">Select</option><option>1m</option><option>5m</option><option>15m</option><option>30m</option><option>1H</option><option>4H</option><option>Daily</option></select></div>
    </div>
    <div class="fg" style="margin-top:2px">
      <label class="lb">Emotion 1–10 (ideal: 4–7, stop if 8+)</label>
      <div class="emg" id="emg"></div>
      <div id="em-w" class="wn" style="display:none">⚠️ DANGER ZONE — Step away. Do NOT trade at 8+</div>
    </div>
    <div class="fg"><label class="lb">Why entering? (write before clicking)</label>
      <input type="text" id="fre" placeholder="e.g. 15m OB retest after BOS, SL below wick"></div>
    <div class="fg"><label class="lb">Post-trade notes</label>
      <input type="text" id="fno" placeholder="What went right / wrong after close"></div>
    <div class="fg"><label class="lb">Trade Rating</label>
      <div class="stg" id="stg"></div></div>
    <div id="cprev" class="cp" style="display:none"></div>
    <div class="mbr">
      <button class="bc" onclick="closeAdd()">CANCEL</button>
      <button class="bs" onclick="saveTrade()">SAVE TRADE</button>
    </div>
  </div>
</div>

<!-- SETTINGS -->
<div class="ov" id="ov-sett" style="display:none" onclick="if(event.target===this)closeSett()">
  <div class="mo">
    <div class="mh"><span class="mt">⚙️ Settings</span><button class="mx" onclick="closeSett()">✕</button></div>
    <div id="sett-body"></div>
  </div>
</div>

<!-- DELETE -->
<div class="ov ovc" id="ov-del" style="display:none">
  <div class="mo moc">
    <div style="font-size:26px;margin-bottom:8px">🗑️</div>
    <div style="font-size:13px;font-weight:700;margin-bottom:5px">Delete this trade?</div>
    <div style="font-size:10px;color:var(--sb);margin-bottom:16px">Cannot be undone.</div>
    <div class="mbr"><button class="bc" onclick="closeDel()">CANCEL</button><button class="bd" onclick="confirmDel()">DELETE</button></div>
  </div>
</div>

<!-- CHECKLIST -->
<div class="ov" id="ov-cl" style="display:none" onclick="if(event.target===this)closeCL()">
  <div class="mo" id="cl-body"></div>
</div>

<!-- JOURNAL ENTRY -->
<div class="ov" id="ov-jn" style="display:none" onclick="if(event.target===this)closeJN()">
  <div class="mo">
    <div class="mh"><span class="mt">📖 Journal Entry</span><button class="mx" onclick="closeJN()">✕</button></div>
    <div class="fg"><label class="lb">Date</label><input type="date" id="jd"></div>
    <div class="fg"><label class="lb">Today's Market Read</label>
      <textarea id="jm" rows="3" style="resize:none" placeholder="What did you see in the market today? HTF bias? Key levels?"></textarea></div>
    <div class="fg"><label class="lb">What I Learned</label>
      <textarea id="jl" rows="3" style="resize:none" placeholder="Key lessons from today's session..."></textarea></div>
    <div class="fg"><label class="lb">Mistakes Made</label>
      <textarea id="jmk" rows="2" style="resize:none" placeholder="Be honest. No growth without honesty."></textarea></div>
    <div class="fg"><label class="lb">Tomorrow's Plan</label>
      <textarea id="jpl" rows="2" style="resize:none" placeholder="Key levels, pairs, setups to watch..."></textarea></div>
    <div class="fg"><label class="lb">Mood (1–10)</label>
      <div class="emg" id="jmg"></div></div>
    <div class="mbr">
      <button class="bc" onclick="closeJN()">CANCEL</button>
      <button class="bs" onclick="saveJN()">SAVE ENTRY</button>
    </div>
  </div>
</div>

<script>
// ─── GRAIN ──────────────────────────────────────────────────────────────────
(function() {
  var c = document.getElementById('grain');
  var ctx = c.getContext('2d');
  var t;
  function draw() {
    var w = c.width = c.offsetWidth;
    var h = c.height = c.offsetHeight;
    var img = ctx.createImageData(w, h);
    for (var i = 0; i < img.data.length; i += 4) {
      var v = Math.random() * 22;
      img.data[i] = v; img.data[i+1] = v; img.data[i+2] = v; img.data[i+3] = 13;
    }
    ctx.putImageData(img, 0, 0);
    t = setTimeout(draw, 120);
  }
  draw();
})();

// ─── STATE ──────────────────────────────────────────────────────────────────
var trades = [];
var journals = [];
var sett = {};
var editId = null;
var delId = null;
var cl = [];
var flt = 'ALL';
var selEmo = '5';
var selStar = 3;
var selJMood = '5';
var charts = {};

var DSETT = {
  acct: 1000, risk: 1, maxDD: 3, maxWDD: 5,
  twrTarget: 60, trrTarget: 2, monthGoal: 200,
  chalTarget: 10, chalDD: 5, chalMode: false
};

var CL_Q = [
  'HTF trend confirmed? (4H / Daily bias clear)',
  'CHoCH or BOS identified on entry timeframe?',
  'Entry from valid OB / FVG / Supply / Demand?',
  'Entry price written before clicking?',
  'Stop loss placed above/below structure wick?',
  'Take profit at minimum 2R from entry?',
  'Lot size calculated using 1% rule?',
  'No high-impact news in next 30 minutes?',
  'Emotion score between 4–7 right now?',
  'Not revenge trading from earlier loss today?',
  'Max 2 trades per day NOT yet reached?',
  'Entering because of RULES — not FEELING?'
];

// ─── STORAGE ────────────────────────────────────────────────────────────────
// Storage with multiple fallbacks
var _store = {};
function _set(k, v) {
  try { localStorage.setItem(k, v); } catch(e) {}
  try { sessionStorage.setItem(k, v); } catch(e) {}
  _store[k] = v;
}
function _get(k) {
  try { var v = localStorage.getItem(k); if (v !== null) return v; } catch(e) {}
