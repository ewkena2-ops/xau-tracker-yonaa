function calcRC() {
  var acct = parseFloat(document.getElementById('rca').value) || sett.acct;
  var risk = parseFloat(document.getElementById('rcr').value) || sett.risk;
  var entry = parseFloat(document.getElementById('rce').value);
  var sl = parseFloat(document.getElementById('rcsl').value);
  var tp = parseFloat(document.getElementById('rctp').value);
  if (!entry || !sl) return;
  var riskAmt = acct * risk / 100;
  var slPips = Math.abs(entry - sl) * 100;
  var pipVal = slPips > 0 ? riskAmt / slPips : 0;
  var lots = (pipVal / 10).toFixed(2);
  var tpPips = tp ? Math.abs(tp - entry) * 100 : 0;
  var reward = tpPips ? pipVal * tpPips : 0;
  var rr = tpPips && slPips ? tpPips / slPips : 0;
  var set = function(id, val) { var el = document.getElementById(id); if (el) el.textContent = val; };
  set('rco-lot', lots);
  set('rco-risk', '$' + riskAmt.toFixed(2));
  set('rco-rew', reward > 0 ? '$' + reward.toFixed(2) : '—');
  set('rco-rr', rr > 0 ? rr.toFixed(2) + 'R' : '—');
  set('rco-pr', slPips.toFixed(1));
  set('rco-pt', tpPips > 0 ? tpPips.toFixed(1) : '—');
}

